{
  "schema_version": 1,
  "corpus_version": "v1",
  "recommended_build_command": "python -m src.process.main build_bbk --logs-dir data/benign_corpus --window-seconds 10",
  "profiles": [
    {
      "profile_id": "browse_order_steady",
      "description": "alice login, browse items, search, order, me, logout; think time 200-400ms"
    },
    {
      "profile_id": "auth_churn",
      "description": "alternate alice/bob login, /api/me, logout; think time 100-250ms"
    },
    {
      "profile_id": "search_lookup_heavy",
      "description": "order then heavy search + order lookup; think time 200-500ms"
    },
    {
      "profile_id": "admin_readonly",
      "description": "bob login, items/search/me readonly; think time 300-600ms"
    },
    {
      "profile_id": "health_idle_poll",
      "description": "/health and /api/items low-frequency poll; think time 3-5s"
    },
    {
      "profile_id": "burst_then_idle",
      "description": "30s high-frequency browse/search then 30s idle polling, looped"
    }
  ],
  "runs": [
    {
      "run_id": "run_a",
      "split_role": "train",
      "duration_seconds": 600,
      "trace_out": "data/benign_corpus/run_a/trace.log",
      "phases": [
        {
          "phase_id": "run_a_phase_01",
          "profile_id": "browse_order_steady",
          "start_offset_seconds": 0.0,
          "end_offset_seconds": 120.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_a_phase_02",
          "profile_id": "auth_churn",
          "start_offset_seconds": 120.0,
          "end_offset_seconds": 240.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_a_phase_03",
          "profile_id": "search_lookup_heavy",
          "start_offset_seconds": 240.0,
          "end_offset_seconds": 360.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_a_phase_04",
          "profile_id": "admin_readonly",
          "start_offset_seconds": 360.0,
          "end_offset_seconds": 480.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_a_phase_05",
          "profile_id": "health_idle_poll",
          "start_offset_seconds": 480.0,
          "end_offset_seconds": 600.0,
          "duration_seconds": 120
        }
      ]
    },
    {
      "run_id": "run_b",
      "split_role": "train",
      "duration_seconds": 600,
      "trace_out": "data/benign_corpus/run_b/trace.log",
      "phases": [
        {
          "phase_id": "run_b_phase_01",
          "profile_id": "admin_readonly",
          "start_offset_seconds": 0.0,
          "end_offset_seconds": 120.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_b_phase_02",
          "profile_id": "search_lookup_heavy",
          "start_offset_seconds": 120.0,
          "end_offset_seconds": 240.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_b_phase_03",
          "profile_id": "browse_order_steady",
          "start_offset_seconds": 240.0,
          "end_offset_seconds": 360.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_b_phase_04",
          "profile_id": "auth_churn",
          "start_offset_seconds": 360.0,
          "end_offset_seconds": 480.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_b_phase_05",
          "profile_id": "health_idle_poll",
          "start_offset_seconds": 480.0,
          "end_offset_seconds": 600.0,
          "duration_seconds": 120
        }
      ]
    },
    {
      "run_id": "run_c",
      "split_role": "calibration",
      "duration_seconds": 600,
      "trace_out": "data/benign_corpus/run_c/trace.log",
      "phases": [
        {
          "phase_id": "run_c_phase_01",
          "profile_id": "burst_then_idle",
          "start_offset_seconds": 0.0,
          "end_offset_seconds": 120.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_c_phase_02",
          "profile_id": "browse_order_steady",
          "start_offset_seconds": 120.0,
          "end_offset_seconds": 240.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_c_phase_03",
          "profile_id": "search_lookup_heavy",
          "start_offset_seconds": 240.0,
          "end_offset_seconds": 360.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_c_phase_04",
          "profile_id": "admin_readonly",
          "start_offset_seconds": 360.0,
          "end_offset_seconds": 480.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_c_phase_05",
          "profile_id": "health_idle_poll",
          "start_offset_seconds": 480.0,
          "end_offset_seconds": 600.0,
          "duration_seconds": 120
        }
      ]
    },
    {
      "run_id": "run_d",
      "split_role": "holdout",
      "duration_seconds": 600,
      "trace_out": "data/benign_corpus/run_d/trace.log",
      "phases": [
        {
          "phase_id": "run_d_phase_01",
          "profile_id": "auth_churn",
          "start_offset_seconds": 0.0,
          "end_offset_seconds": 120.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_d_phase_02",
          "profile_id": "burst_then_idle",
          "start_offset_seconds": 120.0,
          "end_offset_seconds": 240.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_d_phase_03",
          "profile_id": "browse_order_steady",
          "start_offset_seconds": 240.0,
          "end_offset_seconds": 360.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_d_phase_04",
          "profile_id": "search_lookup_heavy",
          "start_offset_seconds": 360.0,
          "end_offset_seconds": 480.0,
          "duration_seconds": 120
        },
        {
          "phase_id": "run_d_phase_05",
          "profile_id": "health_idle_poll",
          "start_offset_seconds": 480.0,
          "end_offset_seconds": 600.0,
          "duration_seconds": 120
        }
      ]
    }
  ]
}