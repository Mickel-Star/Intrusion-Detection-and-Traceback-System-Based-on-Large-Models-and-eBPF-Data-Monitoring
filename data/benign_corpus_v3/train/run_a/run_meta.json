        "distribution": "uniform",
        "max_seconds": 2,
        "min_seconds": 0.5
      },
      "virtual_users": 2
    },
    {
      "actor": "foreground_user",
      "arrival_rate_per_min": 30.0,
      "enabled": true,
      "think_time": {
        "distribution": "uniform",
        "max_seconds": 5,
        "min_seconds": 1
