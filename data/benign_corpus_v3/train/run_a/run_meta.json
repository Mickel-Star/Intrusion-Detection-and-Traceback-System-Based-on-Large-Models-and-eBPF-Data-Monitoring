      "think_time": {
        "distribution": "uniform",
        "max_seconds": 12,
        "min_seconds": 4
      },
      "virtual_users": 1
    },
    {
      "actor": "background_worker",
      "arrival_rate_per_min": 3.0,
      "enabled": true,
      "think_time": {
        "distribution": "lognormal",
        "max_seconds": 18,
        "min_seconds": 3,
        "mu": 1.2,
        "sigma": 0.45
      },
      "virtual_users": 1
    },
    {
      "actor": "burst_retry_user",
      "arrival_rate_per_min": 60.0,
      "enabled": false,
