{
  "scenario_set": "formal_v3",
  "window_seconds": 30,
  "time_bin_seconds": 2,
  "mixed_stage_defaults": {
    "warmup_seconds": 60,
    "cooldown_seconds": 60
  },
  "split_semantics": {
    "attack_dev": "Use only for pipeline debugging and qualitative case studies. Do not use for GMAE training, benign calibration, or threshold selection.",
    "attack_holdout": "Use only for final attack benchmark reporting after threshold selection is frozen."
  },
  "container_roles": {
    "target_containers": [
      {"role": "target", "service": "vuln-app", "container_name": "drsec-target"},
      {"role": "target_dsock", "service": "vuln-app-dsock", "container_name": "drsec-target-dsock"}
    ],
    "supporting_containers": [
      {"role": "c2", "service": "c2-listener", "container_name": "drsec-c2"}
    ],
    "driver_container": {
      "role": "attacker",
      "image": "curlimages/curl:8.6.0",
      "container_name_pattern": "drsec-bench-{scenario_id}-r{repeat_id}-{driver_role}"
    }
  },
  "trace_scope": {
    "scope_expression": ["container", "comm!=tracee"],
    "target_roles": ["target", "target_dsock"],
    "supporting_roles": ["c2"],
    "driver_roles": ["attacker"]
  },
  "scenarios": [
